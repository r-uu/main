# ═══════════════════════════════════════════════════════════════════
# Lokale Docker Umgebungsvariablen
# ═══════════════════════════════════════════════════════════════════
# Kopiere diese Datei nach: config/local/docker/.env.local
# und passe die Werte an deine Entwicklungsumgebung an
#
# WICHTIG: .env.local wird NICHT ins Git committed!
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# PostgreSQL Konfiguration
# ───────────────────────────────────────────────────────────────────
POSTGRES_DB=ruu_dev
POSTGRES_USER=ruu
POSTGRES_PASSWORD=ÄNDERE_MICH_ZU_SICHEREM_PASSWORT
POSTGRES_PORT=5432

# Pfade (relativ zu docker-compose.yml oder absolut)
POSTGRES_DATA_PATH=../../local/docker/data/postgres
POSTGRES_BACKUP_PATH=../../local/docker/backups

# ───────────────────────────────────────────────────────────────────
# Keycloak Konfiguration
# ───────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=ÄNDERE_MICH_ZU_SICHEREM_PASSWORT
KEYCLOAK_PORT=8080
KEYCLOAK_DB=keycloak

# ───────────────────────────────────────────────────────────────────
# Notizen
# ───────────────────────────────────────────────────────────────────
# Nach dem Setup:
# 1. Ändere alle Passwörter oben!
# 2. Keycloak Admin Console: http://localhost:8080/admin
# 3. PostgreSQL: localhost:5432
#
# Weitere maschinenspezifische Konfigurationen hier...

