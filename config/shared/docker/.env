# ═══════════════════════════════════════════════════════════════════
# Gemeinsame Docker Umgebungsvariablen (Standard-Werte)
# ═══════════════════════════════════════════════════════════════════
# Diese Datei wird versioniert und enthält KEINE Secrets!
#
# Überschreibe diese Werte in: config/local/docker/.env.local
# Die .env.local Datei wird NICHT ins Git committed
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────────────────
POSTGRES_DB=ruu_dev
POSTGRES_USER=ruu
POSTGRES_PASSWORD=changeme_in_local_env
POSTGRES_PORT=5432

# Pfade (relativ zu docker-compose.yml)
POSTGRES_DATA_PATH=../../local/docker/data/postgres
POSTGRES_BACKUP_PATH=../../local/docker/backups

# ───────────────────────────────────────────────────────────────────
# Keycloak
# ───────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_in_local_env
KEYCLOAK_PORT=8080
KEYCLOAK_DB=keycloak

# ───────────────────────────────────────────────────────────────────
# Notizen
# ───────────────────────────────────────────────────────────────────
# Nach dem ersten Start:
# - Ändere Passwörter in config/local/docker/.env.local
# - Keycloak Admin Console: http://localhost:8080/admin
# - PostgreSQL: localhost:5432

