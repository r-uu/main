<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane fx:id="root" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="5.0">
               <children>
                  <Label alignment="TOP_LEFT" text="group">
                     <padding>
                        <Insets left="5.0" />
                     </padding>
                  </Label>
                  <HBox fx:id="hBxGroupSelector" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="385.0">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin></HBox>
                  <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0">
                     <children>
                        <Button fx:id="buttonAdd" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="24.0" prefWidth="24.0" HBox.hgrow="NEVER">
                           <graphic>
                              <FontIcon iconLiteral="far-plus-square" iconSize="14" />
                           </graphic>
                           <tooltip>
                              <Tooltip text="create new task group" />
                           </tooltip>
                        </Button>
                        <Button fx:id="buttonEdit" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="24.0" prefWidth="24.0">
                           <graphic>
                              <FontIcon iconLiteral="far-edit" iconSize="14" />
                           </graphic>
                           <tooltip>
                              <Tooltip text="edit task group" />
                           </tooltip>
                        </Button>
                        <Button fx:id="buttonRemove" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="24.0" prefWidth="24.0">
                           <graphic>
                              <FontIcon iconLiteral="far-trash-alt" iconSize="14" />
                           </graphic>
                           <tooltip>
                              <Tooltip text="remove task group" />
                           </tooltip>
                        </Button>
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </HBox>
                  <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="100.0" />
                  <Button fx:id="buttonBackup" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="24.0" prefWidth="24.0">
                     <graphic>
                        <FontIcon iconLiteral="fas-database" iconSize="14" />
                     </graphic>
                     <tooltip>
                        <Tooltip text="open backup dialog" />
                     </tooltip>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </Button>
                  <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="100.0" HBox.hgrow="ALWAYS" />
                  <Button fx:id="buttonExit" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" prefHeight="24.0" prefWidth="24.0">
                     <graphic>
                        <FontIcon iconLiteral="far-arrow-alt-circle-left" iconSize="14" />
                     </graphic>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <tooltip>
                        <Tooltip text="back" />
                     </tooltip>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets bottom="5.0" right="5.0" top="5.0" />
               </VBox.margin>
            </HBox>
            <ScrollPane fitToHeight="true" fitToWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
               <content>
                  <SplitPane fx:id="spltPane" dividerPositions="0.33, 0.66" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
                     <items>
                        <AnchorPane fx:id="nchrPnPredecessors" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" />
                        <AnchorPane fx:id="nchrPnSuperSubTasks" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" />
                        <AnchorPane fx:id="nchrPnSuccessors" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" />
                     </items>
                  </SplitPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
