<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TreeTableView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.AnchorPane?>

<!--
  Hybrid Gantt Chart Layout
  
  Uses a split design:
  - Left: TreeTableView showing task hierarchy (fixed/resizable, always visible)
  - Right: ScrollPane with Canvas showing timeline (scrollable horizontally)
  
  This solves the "frozen column" problem naturally without complex synchronization.
-->
<AnchorPane fx:id="root" 
    maxHeight="1.7976931348623157E308" 
    maxWidth="1.7976931348623157E308"
    minHeight="400.0" 
    minWidth="800.0" 
    prefHeight="600.0" 
    prefWidth="1200.0"
    xmlns="http://javafx.com/javafx/25" 
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="de.ruu.app.jeeeraaah.frontend.ui.fx.task.gantt.HybridGanttController">
    
    <children>
        <HBox fx:id="hybridContainer" 
            spacing="0.0"
            AnchorPane.bottomAnchor="0.0" 
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" 
            AnchorPane.topAnchor="0.0">
            
            <!-- Left Panel: Task Tree (Always Visible) -->
            <TreeTableView fx:id="taskTree" 
                prefWidth="400.0" 
                minWidth="200.0"
                maxWidth="600.0"
                maxHeight="1.7976931348623157E308">
            </TreeTableView>
            
            <!-- Right Panel: Timeline Canvas (Horizontally Scrollable) -->
            <ScrollPane fx:id="timelineScrollPane"
                fitToHeight="true"
                hbarPolicy="ALWAYS"
                vbarPolicy="NEVER"
                maxHeight="1.7976931348623157E308"
                HBox.hgrow="ALWAYS">
                <!-- Canvas will be added programmatically -->
            </ScrollPane>
            
        </HBox>
    </children>
</AnchorPane>
