<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="invoice" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="30" bottomMargin="30">

    <!-- Parameters from InvoiceData -->
    <parameter name="invoiceNumber" class="java.lang.String"/>
    <parameter name="invoiceDate" class="java.lang.String"/>
    <parameter name="dueDate" class="java.lang.String"/>
    <parameter name="customerName" class="java.lang.String"/>
    <parameter name="customerAddress" class="java.lang.String"/>
    <parameter name="subtotal" class="java.lang.Double"/>
    <parameter name="tax" class="java.lang.Double"/>
    <parameter name="total" class="java.lang.Double"/>
    <parameter name="notes" class="java.lang.String"/>

    <!-- Title -->
    <title>
        <band height="150">
            <!-- Rechnung Header -->
            <staticText>
                <reportElement x="0" y="0" width="535" height="40"/>
                <textElement textAlignment="Right">
                    <font size="24" isBold="true"/>
                </textElement>
                <text><![CDATA[RECHNUNG]]></text>
            </staticText>

            <!-- Rechnungsnummer und Datum -->
            <textField>
                <reportElement x="350" y="50" width="185" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Rechnungsnr.: " + $P{invoiceNumber}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="350" y="70" width="185" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Datum: " + $P{invoiceDate}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="350" y="90" width="185" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Fällig: " + $P{dueDate}]]></textFieldExpression>
            </textField>

            <!-- Kundenadresse -->
            <staticText>
                <reportElement x="0" y="50" width="100" height="20"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Rechnung an:]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="70" width="250" height="40"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{customerName} + "\n" + $P{customerAddress}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- Column Headers -->
    <columnHeader>
        <band height="30">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="25" backcolor="#E0E0E0"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="10" y="5" width="285" height="15"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Beschreibung]]></text>
            </staticText>

            <staticText>
                <reportElement x="300" y="5" width="60" height="15"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Menge]]></text>
            </staticText>

            <staticText>
                <reportElement x="365" y="5" width="80" height="15"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Einzelpreis]]></text>
            </staticText>

            <staticText>
                <reportElement x="450" y="5" width="75" height="15"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Gesamt]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Summary/Footer -->
    <summary>
        <band height="200">
            <!-- Zwischensumme -->
            <line>
                <reportElement x="350" y="10" width="185" height="1"/>
            </line>

            <staticText>
                <reportElement x="350" y="20" width="95" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[Zwischensumme:]]></text>
            </staticText>

            <textField pattern="#,##0.00 €">
                <reportElement x="450" y="20" width="75" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{subtotal}]]></textFieldExpression>
            </textField>

            <!-- MwSt -->
            <staticText>
                <reportElement x="350" y="40" width="95" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[MwSt. (19%):]]></text>
            </staticText>

            <textField pattern="#,##0.00 €">
                <reportElement x="450" y="40" width="75" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{tax}]]></textFieldExpression>
            </textField>

            <!-- Gesamtbetrag -->
            <line>
                <reportElement x="350" y="65" width="185" height="1"/>
                <graphicElement>
                    <pen lineWidth="2"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="350" y="70" width="95" height="25"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Gesamt:]]></text>
            </staticText>

            <textField pattern="#,##0.00 €">
                <reportElement x="450" y="70" width="75" height="25"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{total}]]></textFieldExpression>
            </textField>

            <!-- Notizen -->
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="120" width="535" height="60"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement>
                    <font size="9" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{notes} != null ? "Hinweise:\n" + $P{notes} : ""]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>

