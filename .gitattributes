# Git Line Ending Configuration
# Verhindert CRLF-Probleme in WSL/Linux-Umgebungen

# Default: Auto-Konvertierung
* text=auto

# Shell-Skripte: IMMER LF (Linux/Unix)
*.sh text eol=lf

# Batch/PowerShell: IMMER CRLF (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Konfigurationsdateien: LF bevorzugt
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.json text eol=lf

# Java-Dateien: LF bevorzugt
*.java text eol=lf
*.kt text eol=lf

# Markdown/Dokumentation: LF bevorzugt
*.md text eol=lf
*.txt text eol=lf

# Binärdateien
*.jar binary
*.war binary
*.ear binary
*.class binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.pptx binary

